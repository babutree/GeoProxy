# Docker container name
CONTAINER_NAME=goproxy

# Ports
WEBUI_PORT=7800
SOCKS5_PORT=7801
HTTP_PORT=7802

# WebUI admin password
WEBUI_PASSWORD=goproxy

# Proxy authentication
PROXY_AUTH_ENABLED=false
PROXY_AUTH_USERNAME=acct
PROXY_AUTH_PASSWORD=

# Username DSL defaults
# DEFAULT_REGION applies when the proxy username has no -region- suffix.
# Example username: acct-region-us-session-browser
SESSION_TTL_MINUTES=10
DEFAULT_REGION=

# Geo filters
# ALLOWED_COUNTRIES takes priority when set, for example: US,JP,SG
ALLOWED_COUNTRIES=
# BLOCKED_COUNTRIES is used only when ALLOWED_COUNTRIES is empty.
BLOCKED_COUNTRIES=

# Health and retry behavior
HEALTH_CHECK_INTERVAL=5
MAX_RETRY=3

# Subscription and encrypted manual single-link conversion
SINGBOX_PATH=sing-box

# Optional local data directory. docker-compose sets DATA_DIR=/app/data inside the container.
# DATA_DIR=./data

# Timezone
TZ=Asia/Shanghai
